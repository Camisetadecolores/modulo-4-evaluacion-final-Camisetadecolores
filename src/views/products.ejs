<!DOCTYPE html>
<html lang="en">
  <%- include("./head") %>

  <body class="shop-view">
    <%- include("./partials/header") %>

    <main class="shop">
      <h2 class="shop__title">Tienda</h2>

    <nav class="shop-filters">
      <div class="shop-filters__group">
        <a
          href="/products"
          class="shop-filters__button <%= currentCategory === 'all' ? 'is-active' : '' %>"
        >
          Todos
        </a>

        <a
          href="/products?category=bienestar<%= currentSort ? '&sort=' + currentSort : '' %>"
          class="shop-filters__button <%= currentCategory === 'bienestar' ? 'is-active' : '' %>"
        >
          Bienestar
        </a>

        <a
          href="/products?category=tecnología<%= currentSort ? '&sort=' + currentSort : '' %>"
          class="shop-filters__button <%= currentCategory === 'tecnología' ? 'is-active' : '' %>"
        >
          Tecnología
        </a>

        <a
          href="/products?category=gadgets<%= currentSort ? '&sort=' + currentSort : '' %>"
          class="shop-filters__button <%= currentCategory === 'gadgets' ? 'is-active' : '' %>"
        >
          Gadgets
        </a>
      </div>

      <div class="shop-filters__group">
        <a
          href="/products?<%= currentCategory !== 'all' ? 'category=' + currentCategory + '&' : '' %>sort=price-asc"
          class="shop-filters__button <%= currentSort === 'price-asc' ? 'is-active' : '' %>"
        >
          Precio ↑
        </a>

        <a
          href="/products?<%= currentCategory !== 'all' ? 'category=' + currentCategory + '&' : '' %>sort=price-desc"
          class="shop-filters__button <%= currentSort === 'price-desc' ? 'is-active' : '' %>"
        >
          Precio ↓
        </a>

        <a
          href="/products?<%= currentCategory !== 'all' ? 'category=' + currentCategory + '&' : '' %>sort=name-asc"
          class="shop-filters__button <%= currentSort === 'name-asc' ? 'is-active' : '' %>"
        >
          A-Z
        </a>

        <a
          href="/products?<%= currentCategory !== 'all' ? 'category=' + currentCategory + '&' : '' %>sort=name-desc"
          class="shop-filters__button <%= currentSort === 'name-desc' ? 'is-active' : '' %>"
        >
          Z-A
        </a>
      </div>
    </nav>

      <% if (products.length === 0) { %>
        <p class="shop__empty">No products available.</p>
      <% } else { %>
        <section class="shop-list">
          <% products.forEach((product, index) => { %>

            <article class="shop-list__product shop-list__product--<%= index % 3 %>">
              
              <!-- CARD CLICABLE -->
              <a href="/products/<%= product.id %>" class="shop-list__link">
                <h3 class="shop-list__title"><%= product.name %></h3>

                <img
                  class="shop-list__image"
                  src="<%= product.image %>"
                  alt="Product image"
                />

                <p class="shop-list__price">
                  <strong><%= product.price %> €</strong>
                </p>
              </a>

              <!-- ACCIONES -->
              <% if (product.stock > 0) { %>
                <form class="shop-list__form" action="/cart" method="POST">
                  <input type="hidden" name="product_id" value="<%= product.id %>" />

                  <label for="quantity-<%= product.id %>">Cantidad:</label>

                  <input
                    id="quantity-<%= product.id %>"
                    class="shop-list__input"
                    type="number"
                    name="quantity"
                    min="1"
                    max="<%= product.stock %>"
                    value="1"
                    required
                  />

                  <button class="shop-list__button" type="submit">
                    Añadir al carrito
                  </button>
                </form>
              <% } else { %>
                <p class="shop-list__out">
                  <strong>Out of stock</strong>
                </p>
              <% } %>

            </article>

          <% }) %>
        </section>
      <% } %>
    </main>

    <%- include("./partials/footer") %>
    <script src="/js/menuHamburger.js"></script>
  </body>
</html>