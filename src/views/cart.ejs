<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Carrito de compra</title>
  </head>
  <body>
    <h1>Carrito de compra</h1>

    <table border="1">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% cart.forEach((item) => { %>
        <tr>
          <td><%= item.name %></td>
          <td><%= item.price %> €</td>
          <td><%= item.quantity %></td>
          <td><%= item.subtotal %> €</td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <h2>Total: <%= total %> €</h2>
  </body>
</html>