<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Carrito de compra</title>
  </head>
  <body>
    <h1>Carrito de compra</h1>

    <table border="1">
      <thead>
        <tr>
          <th></th>
          <th></th>
          <th></th>
          <th></th>
          <th></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% cart.forEach((item) => { %>
        <tr>
          <td>
            <img src="<%= item.image %>" alt="<%= item.name %>" width="80">
          </td>
          <td><%= item.name %></td>
          <td><%= item.price %> €</td>
          <td><%= item.quantity %></td>
          <td><%= item.subtotal %> €</td>
          <td>
            <form action="/cart/increase/<%= item.product_id %>" method="POST" style="display:inline;">
              <button type="submit">+</button>
            </form>

            <form action="/cart/decrease/<%= item.product_id %>" method="POST" style="display:inline;">
              <button type="submit">-</button>
            </form>

            <form action="/cart/delete/<%= item.product_id %>" method="POST" style="display:inline;">
              <button type="submit">Borrar</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <h2>Total: <%= total %> €</h2>
  </body>
</html>